{
  "name": "@annondeveloper/ui-kit",
  "version": "0.1.0",
  "type": "module",
  "description": "A React component library with dark/light theming, built on Radix UI, Tailwind CSS v4, and Framer Motion.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./form": {
      "import": "./dist/form.js",
      "types": "./dist/form.d.ts"
    },
    "./theme.css": "./src/theme.css"
  },
  "bin": {
    "ui-kit": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "src/theme.css",
    "src/utils.ts",
    "src/components/"
  ],
  "scripts": {
    "build": "tsup && tsup --config tsup.cli.config.ts && node -e \"const f='dist/cli/index.js',c=require('fs');c.writeFileSync(f,'#!/usr/bin/env node\\n'+c.readFileSync(f,'utf8'))\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "prepublishOnly": "npm run typecheck && npm run build && npm test",
    "release": "npm version patch && git push --follow-tags",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static"
  },
  "peerDependencies": {
    "@radix-ui/react-alert-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-popover": "^1.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "clsx": "^2.0.0",
    "framer-motion": "^12.0.0",
    "lucide-react": ">=0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@radix-ui/react-alert-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-popover": "^1.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tanstack/react-table": "^8.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "axe-core": "^4.11.1",
    "clsx": "^2.0.0",
    "framer-motion": "^12.0.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.0",
    "lucide-react": ">=0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.0",
    "storybook": "^8.6.18",
    "tailwind-merge": "^2.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "@annondeveloper:registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/annondeveloper/ui-kit.git"
  },
  "license": "MIT",
  "keywords": [
    "react",
    "components",
    "ui-kit",
    "tailwind",
    "radix-ui",
    "framer-motion",
    "dark-mode",
    "design-system",
    "typescript"
  ],
  "sideEffects": false
}
