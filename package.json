{
  "name": "@annondeveloper/ui-kit",
  "version": "0.2.2",
  "type": "module",
  "description": "A React component library with dark/light theming, built on Radix UI, Tailwind CSS v4, and Framer Motion.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./form": {
      "import": "./dist/form.js",
      "types": "./dist/form.d.ts"
    },
    "./theme.css": "./src/theme.css"
  },
  "bin": {
    "ui-kit": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "src/theme.css",
    "src/utils.ts",
    "src/components/"
  ],
  "scripts": {
    "build": "tsup && tsup --config tsup.cli.config.ts && node -e \"const f='dist/cli/index.js',c=require('fs');c.writeFileSync(f,'#!/usr/bin/env node\\n'+c.readFileSync(f,'utf8'))\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "prepublishOnly": "npm run typecheck && npm run build && npm test",
    "release": "npm version patch && git push --follow-tags",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static"
  },
  "peerDependencies": {
    "@radix-ui/react-alert-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-popover": "^1.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "clsx": "^2.0.0",
    "framer-motion": "^12.0.0",
    "lucide-react": ">=0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^2.0.0 || ^3.0.0"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@storybook/addon-a11y": "^10.3.0",
    "@storybook/react": "^10.3.0",
    "@storybook/react-vite": "^10.3.0",
    "@tanstack/react-table": "^8.21.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "axe-core": "^4.11.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.0",
    "lucide-react": ">=0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "storybook": "^10.3.0",
    "tailwind-merge": "^3.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/annondeveloper/ui-kit.git"
  },
  "license": "MIT",
  "keywords": [
    "react",
    "components",
    "ui-kit",
    "tailwind",
    "radix-ui",
    "framer-motion",
    "dark-mode",
    "design-system",
    "typescript"
  ],
  "sideEffects": false
}
