{
  "name": "@annondeveloper/ui-kit",
  "version": "0.1.0",
  "type": "module",
  "description": "A React component library with dark/light theming, built on Radix UI, Tailwind CSS v4, and Framer Motion.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theme.css": "./src/theme.css"
  },
  "files": [
    "dist",
    "src/theme.css"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "framer-motion": "^12.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-alert-dialog": "^1.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "lucide-react": ">=0.400.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0",
    "sonner": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "@tanstack/react-table": "^8.0.0",
    "framer-motion": "^12.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-alert-dialog": "^1.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "lucide-react": ">=0.400.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0",
    "sonner": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "@annondeveloper:registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/annondeveloper/ui-kit.git"
  },
  "license": "MIT",
  "keywords": [
    "react",
    "components",
    "ui-kit",
    "tailwind",
    "radix-ui",
    "framer-motion",
    "dark-mode",
    "design-system",
    "typescript"
  ],
  "sideEffects": false
}
